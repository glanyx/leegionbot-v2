{
  "name": "leegionbot",
  "version": "3.0.0",
  "description": "Private Discord Bot for LeeandLie",
  "main": "index.js",
  "scripts": {
    "start": "ts-node --files -r dotenv/config src/index.ts",
    "stop": "pkill --signal SIGINT leegionbot",
    "test": "jest",
    "build": "tsc",
    "dev": "ts-node -r dotenv/config src/index.ts",
    "compiled": "node -r dotenv/config build/src/index.js",
    "docker": "docker build -t leegionbot ."
  },
  "author": "Glanyx",
  "license": "ISC",
  "dependencies": {
    "@discordjs/builders": "^1.13.1",
    "@discordjs/rest": "^2.6.0",
    "@sentry/node": "^10.38.0",
    "@sentry/tracing": "^7.120.4",
    "axios": "^1.13.5",
    "discord-api-types": "^0.38.38",
    "discord.js": "^14.25.1",
    "dotenv": "^17.2.4",
    "enmap": "^6.1.6",
    "esm": "^3.2.25",
    "log4js": "^6.9.1",
    "node-schedule": "^2.1.1",
    "pg": "^8.18.0",
    "pureimage": "^0.4.18",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@types/jest": "^30.0.0",
    "@types/node-schedule": "^2.1.8",
    "@types/pg": "^8.16.0",
    "babel-jest": "^30.2.0",
    "jest": "^30.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "jest": {
    "testEnvironment": "node"
  }
}